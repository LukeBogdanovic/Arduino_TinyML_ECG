{
    "name": "Arduino TinyML ECG",
    "build": {
        "dockerfile": "../Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.pylint",
                "ms-vscode.cpptools"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/venv/bin/python",
                "arduino.commandPath": "/usr/local/bin/arduino-cli",
                "arduino.useArduinoCli": true
            }
        }
    },
    "workspaceFolder": "/project",
    "mounts": [
        "source=arduino-project,target=/project,type=volume"
    ],
    "runArgs": [
        "--gpus=all",
        "--privileged"
    ],
    "remoteUser": "root"
}
